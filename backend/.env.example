# Copy this file to .env and fill in your key.
# The app runs fine even without a key (falls back to keyword-based intent
# classification and template-based replies), but responses are much better
# and more natural with an LLM configured.
#
# Get a free Google API key at: https://aistudio.google.com/apikey
# (no billing card required for the free tier)

GOOGLE_API_KEY=your_google_api_key_here
LLM_MODEL=gemini-2.0-flash

# Defaults to a local SQLite file - swap for a Postgres URL in production, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/niyamguard
DATABASE_URL=sqlite:///./niyamguard.db
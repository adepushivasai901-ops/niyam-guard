# Copy this file to .env - Ollama runs locally, so there's no API key to set.
#
# Prerequisite: install Ollama (https://ollama.com/download) and pull a model:
#   ollama pull llama3.2
#
# The app still runs and answers correctly even if Ollama isn't running -
# it falls back to keyword-based intent classification and template-based
# replies - so you are never blocked even if Ollama has an issue.

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Defaults to a local SQLite file - swap for a Postgres URL in production, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/niyamguard
DATABASE_URL=sqlite:///./niyamguard.db